# Configuración de Variables de Entorno
# Copia este archivo como .env y configura tus valores

# Puerto del servidor Node.js
PORT=3000

# Configuración de Base de Datos SQL Server
DB_USER=sa
DB_PASSWORD=tu_contraseña_aqui
DB_SERVER=localhost
DB_NAME=OrdenExpress
DB_PORT=1433

# Configuración JWT (opcional para sesiones)
JWT_SECRET=tu_secreto_aqui

# Configuración Stripe (para pagos)
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# URL API . de laNET (para producción)
# API_URL=http://localhost:5022

# Configuración de producción (descomenta para producción)
# DB_SERVER=tu-servidor-sql.azure.com
# DB_ENCRYPT=true

